# Flask environment mode (development enables debug and auto-reload)
FLASK_ENV=development

# Flask app entry point (the main app file to run)
FLASK_APP=app.py

# Enable Flask debug mode (shows detailed error messages and debugger)
DEBUG=True

# Secret key for Flask sessions and CSRF protection (generate a random string in production)
SECRET_KEY=change_this_in_production

# OpenAI API key for AI features (get from https://platform.openai.com/account/api-keys)
OPENAI_API_KEY=your_openai_key_here

# Groq API key for fast AI inference (get from https://console.groq.com)
# Required for: Hero AI recommendations, Adventure planning
GROQ_KEY=your_groq_key_here

# ExchangeRate API key for currency conversion (get from https://www.exchangerate-api.com)
EXCHANGE_KEY=your_exchange_key_here

# Database URL (SQLite by default, can use PostgreSQL, MySQL, etc.)
DATABASE_URL=sqlite:///travel.db

# ============================================================================
# CI/CD Configuration (for Jenkins pipeline)
# ============================================================================

# Application environment: development or production
# Used by Jenkins pipeline to determine deployment behavior
APP_ENV=production

# Docker Compose project name - used as prefix for container/network names
# Must be lowercase and no spaces
# Helps distinguish between dev and CI environments
COMPOSE_PROJECT_NAME=travelplanner
