FLASK_ENV=development
FLASK_DEBUG=true
PORT=3001
FRONTEND_URL=http://localhost:5500

# ── DATABASE ─────────────────────────────────────────
# MongoDB connection (local or MongoDB Atlas)
MONGO_URI=mongodb://localhost:27017/
MONGO_DB_NAME=travel_planner
# For MongoDB Atlas, use: mongodb+srv://username:password@cluster.mongodb.net/

# ── API Keys ─────────────────────────────────────────
# Get these from the respective services
OPENWEATHER_KEY=your_key_here
EXCHANGE_KEY=your_key_here
AMADEUS_KEY=your_key_here
AMADEUS_SECRET=your_secret_here
RAPIDAPI_KEY=your_key_here
ANTHROPIC_KEY=your_key_here
GROQ_KEY=your_key_here
